+// RS_NANO_NEON_X4: gcc<9 aarch64 lacks the _x2/_x4 vector-load intrinsics
+#if defined(__GNUC__) && !defined(__clang__) && __GNUC__ < 9
+static inline int16x8x2_t  ggml_vld1q_s16_x2(const int16_t*p){int16x8x2_t r;r.val[0]=vld1q_s16(p);r.val[1]=vld1q_s16(p+8);return r;}
